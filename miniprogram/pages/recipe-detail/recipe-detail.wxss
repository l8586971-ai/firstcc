.reminder-banner {
  background: #FFF8E1;
  border: 2rpx solid #FFB300;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #F57F17;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-header {
  padding: 28rpx;
}

.detail-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
}

.detail-meta {
  justify-content: space-around;
}

.meta-item {
  text-align: center;
}

.meta-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.meta-value.match-rate.high { color: #4CAF50; }
.meta-value.match-rate.mid { color: #FF9800; }
.meta-value.match-rate.low { color: #f44336; }

.meta-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.ing-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.ing-row:last-child {
  border-bottom: none;
}

.ing-name {
  font-size: 28rpx;
  color: #333;
}

.ing-amount {
  font-size: 24rpx;
  color: #666;
}

.ing-stock {
  font-size: 22rpx;
}

.video-info {
  background: #F5F5F5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.watch-video-btn {
  text-align: center;
  background: #E3F2FD;
  color: #2196F3;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.steps-list {
  counter-reset: step;
}

.step-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding-top: 8rpx;
}

.recipe-tips {
  background: #E8F5E9;
  padding: 16rpx;
  border-radius: 10rpx;
}

.detail-actions {
  padding-bottom: 40rpx;
}

.detail-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}
