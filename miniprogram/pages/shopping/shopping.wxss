.shop-header {
  padding: 20rpx 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.header-sub {
  display: block;
}

.refresh-btn {
  background: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.stats-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.stat-num.success { color: #4CAF50; }
.stat-num.warning { color: #FF9800; }
.stat-num.danger { color: #f44336; }

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.shop-item {
  position: relative;
}

.shop-item.purchased {
  opacity: 0.6;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 600;
}

.shop-info {
  font-size: 24rpx;
  color: #999;
}

.suggest-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9800;
}

.stock-in-btn {
  background: #4CAF50;
  color: #fff;
  padding: 12rpx 32rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.purchased-info {
  background: #E8F5E9;
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
}

.batch-action {
  padding: 24rpx 0;
}

.batch-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 16rpx;
}

.modal-name {
  font-size: 30rpx;
  font-weight: 600;
}

.modal-suggest {
  background: #FFF8E1;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.modal-footer {
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}
