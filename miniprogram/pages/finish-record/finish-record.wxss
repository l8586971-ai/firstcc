.page-header {
  padding: 20rpx 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.header-sub {
  font-size: 28rpx;
  color: #666;
  display: block;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.consume-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.consume-item:last-child {
  border-bottom: none;
}

.consume-name {
  font-size: 28rpx;
  font-weight: 600;
}

.consume-field {
  width: 100rpx;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

.eval-item {
  padding: 8rpx 0;
}

.eval-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.tag-select {
  gap: 12rpx;
}

.tag-select .tag {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.short-field {
  width: 200rpx;
}

.note-field {
  min-height: 120rpx;
  padding: 16rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.submit-area {
  padding-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}
