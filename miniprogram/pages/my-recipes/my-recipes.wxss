.page-header {
  padding: 20rpx 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.rank-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #999;
  margin-right: 16rpx;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 500;
}

.rank-count {
  font-size: 26rpx;
  color: #999;
}

.rank-date {
  display: block;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.empty-sub-state {
  padding: 24rpx 0;
  text-align: center;
}
