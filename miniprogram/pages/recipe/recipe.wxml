<view class="container">
  <!-- 顶部标题栏 -->
  <view class="recipe-header flex-between">
    <text class="header-title">📖 菜谱</text>
    <view class="header-actions flex-row">
      <text class="header-link" bindtap="onMyRecipes">我的菜谱</text>
      <text class="header-link" bindtap="onHistory">历史记录</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list flex-row">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{activeCategory === item.key ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item.key}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 生成按钮 -->
  <view class="generate-area mt-24">
    <view class="generate-btn" bindtap="onGenerate">
      <text class="generate-icon">🎯</text>
      <text class="generate-text">根据冰箱库存生成食谱</text>
      <text class="generate-hint">根据 {{activeCategory === 'all' ? '全部食材' : activeCategory}} 匹配</text>
    </view>
  </view>

  <!-- 食谱列表 -->
  <view class="recipe-list mt-24">
    <block wx:for="{{recipes}}" wx:key="id">
      <recipe-card
        recipe="{{item}}"
        bind:detail="onRecipeDetail"
      />
    </block>

    <!-- 空状态 -->
    <view wx:if="{{!hasGenerated && recipes.length === 0}}" class="empty-state">
      <text class="empty-icon">🍲</text>
      <text>点击上方按钮生成今日食谱</text>
    </view>

    <view wx:if="{{hasGenerated && recipes.length === 0}}" class="empty-state">
      <text class="empty-icon">😅</text>
      <text>当前分类下没有匹配的食谱</text>
      <text class="text-sm text-muted mt-12">试试其他分类或添加更多食材</text>
    </view>
  </view>

  <!-- 我的菜谱排行榜（生成食谱后展示） -->
  <view wx:if="{{hasGenerated}}" class="my-recipes-section mt-24">
    <view class="section-header flex-between">
      <text class="section-title">🏆 我的菜谱</text>
      <text class="section-more" bindtap="onMyRecipes">查看更多 →</text>
    </view>

    <!-- 最常做 -->
    <view class="card rank-card mt-24" wx:if="{{topCooked.length > 0}}">
      <text class="rank-label">🔥 最常做</text>
      <view wx:for="{{topCooked}}" wx:key="recipeId" class="rank-item flex-between mt-12">
        <text class="rank-name">{{item.recipeName}}</text>
        <text class="rank-count">{{item.cookCount}} 次</text>
      </view>
    </view>

    <!-- 最高评分 -->
    <view class="card rank-card mt-24" wx:if="{{topRated.length > 0}}">
      <text class="rank-label">⭐ 最高评分</text>
      <view wx:for="{{topRated}}" wx:key="recipeId" class="rank-item flex-between mt-12">
        <text class="rank-name">{{item.recipeName}}</text>
        <text class="rank-count">{{item.stars}} {{item.avgRating}}</text>
      </view>
    </view>

    <!-- 最近制作 -->
    <view class="card rank-card mt-24" wx:if="{{recentMade.length > 0}}">
      <text class="rank-label">🕐 最近制作</text>
      <view wx:for="{{recentMade}}" wx:key="id" class="rank-item flex-between mt-12">
        <text class="rank-name">{{item.recipeName}}</text>
        <text class="rank-count text-sm text-muted">{{item.cookDate}}</text>
      </view>
    </view>
  </view>
</view>
