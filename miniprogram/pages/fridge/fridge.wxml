<view class="container">
  <!-- 顶部操作栏 -->
  <view class="fridge-header flex-between">
    <text class="header-title">🧊 我的冰箱</text>
    <view class="add-btn" bindtap="onAddFood">
      <text class="add-icon">+</text>
      <text>添加食材</text>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-bar flex-between mt-24">
    <view class="stat-item">
      <text class="stat-num">{{inventory.length}}</text>
      <text class="stat-label">总食材</text>
    </view>
    <view class="stat-item">
      <text class="stat-num warning">{{expiringCount}}</text>
      <text class="stat-label">临期</text>
    </view>
    <view class="stat-item">
      <text class="stat-num danger">{{lowStockCount}}</text>
      <text class="stat-label">低库存</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{expiredCount}}</text>
      <text class="stat-label">已过期</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll mt-24" scroll-x>
    <view class="category-list flex-row">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{activeCategory === item.key ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item.key}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 食材列表 -->
  <view class="food-list mt-24">
    <block wx:for="{{filteredInventory}}" wx:key="id">
      <food-card
        food="{{item}}"
        showActions="{{true}}"
        bind:edit="onEditFood"
        bind:delete="onDeleteFood"
        bind:tap="onFoodTap"
      />
    </block>

    <!-- 空状态 -->
    <view wx:if="{{filteredInventory.length === 0}}" class="empty-state">
      <text class="empty-icon">🛒</text>
      <text>冰箱还是空的，快去添加食材吧</text>
      <view class="btn-primary mt-24" bindtap="onAddFood">
        <text>添加食材</text>
      </view>
    </view>
  </view>
</view>
