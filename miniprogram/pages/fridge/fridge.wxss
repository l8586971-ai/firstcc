.fridge-header {
  padding: 20rpx 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.add-btn {
  background: #4CAF50;
  color: #fff;
  padding: 14rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 700;
}

.stats-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.stat-num.warning { color: #FF9800; }
.stat-num.danger { color: #f44336; }

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  background: #fff;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.category-item.active {
  background: #4CAF50;
  color: #fff;
}

.food-list {
  padding-bottom: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}
