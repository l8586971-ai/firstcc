<view class="step-indicator">
  <view class="step-progress flex-row">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{(current + 1) / total * 100}}%"></view>
    </view>
    <text class="progress-text">第 {{current + 1}} 步 / 共 {{total}} 步</text>
  </view>

  <view class="step-content mt-24">
    <view class="step-number">{{current + 1}}</view>
    <view class="step-text">
      <text>{{stepText}}</text>
    </view>
  </view>

  <view class="step-hint mt-12" wx:if="{{hint}}">
    <text class="hint-label">提示：</text>
    <text>{{hint}}</text>
  </view>

  <view class="step-btns flex-between mt-48">
    <button class="step-btn prev-btn {{current === 0 ? 'disabled' : ''}}" bindtap="onPrev" disabled="{{current === 0}}">
      上一步
    </button>
    <button class="step-btn next-btn" bindtap="onNext">
      {{current === total - 1 ? '完成' : '下一步'}}
    </button>
  </view>
</view>
