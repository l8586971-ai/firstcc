.step-indicator {
  padding: 24rpx;
}

.step-progress {
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #4CAF50;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}

.step-content {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  min-height: 200rpx;
}

.step-number {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.step-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.step-hint {
  background: #FFF8E1;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #F57F17;
}

.hint-label {
  font-weight: 600;
}

.step-btns {
  gap: 24rpx;
}

.step-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
}

.step-btn::after {
  border: none;
}

.prev-btn {
  background: #f5f5f5;
  color: #666;
}

.prev-btn.disabled {
  opacity: 0.4;
}

.next-btn {
  background: #4CAF50;
  color: #fff;
}

.next-btn:active {
  background: #43A047;
}
