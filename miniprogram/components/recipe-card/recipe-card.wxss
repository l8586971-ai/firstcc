.recipe-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.recipe-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.match-rate {
  text-align: center;
}

.rate-num {
  font-size: 36rpx;
  font-weight: 700;
}

.rate-num.high { color: #4CAF50; }
.rate-num.mid { color: #FF9800; }
.rate-num.low { color: #f44336; }

.rate-label {
  font-size: 20rpx;
  color: #999;
  display: block;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
  margin-right: 24rpx;
}

.ing-list {
  gap: 8rpx;
}

.ing-item {
  font-size: 24rpx;
}

.ing-item .has {
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.ing-item .miss {
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.missing-section {
  background: #FFF8E1;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.sub-section {
  background: #E8F5E9;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.video-source {
  background: #F5F5F5;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.platform-tag {
  font-size: 20rpx;
  flex-shrink: 0;
}

.video-title {
  font-size: 24rpx;
  color: #666;
  max-width: 350rpx;
}

.recipe-actions {
  gap: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.detail-btn {
  background: #E8F5E9;
  color: #4CAF50;
}

.video-btn {
  background: #E3F2FD;
  color: #2196F3;
}
