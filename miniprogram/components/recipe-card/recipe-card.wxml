<view class="recipe-card" bindtap="onTap">
  <!-- 头部 -->
  <view class="recipe-header flex-between">
    <view class="flex-row">
      <text class="recipe-name">{{recipe.name}}</text>
      <text class="tag tag-green ml-12">{{recipe.category}}</text>
    </view>
    <view class="match-rate">
      <text class="rate-num {{matchRate >= 75 ? 'high' : matchRate >= 50 ? 'mid' : 'low'}}">{{recipe.matchRate}}%</text>
      <text class="rate-label">匹配</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="recipe-meta flex-row mt-12">
    <text class="meta-item">⏱ {{recipe.cookTime}}分钟</text>
    <text class="meta-item">📊 {{recipe.difficultyLabel}}</text>
    <text class="meta-item">🍽 1人份</text>
  </view>

  <!-- 食材匹配 -->
  <view class="recipe-ingredients mt-24">
    <view class="ing-title text-sm text-muted">所需食材</view>
    <view class="ing-list flex-wrap mt-12">
      <view wx:for="{{recipe.ingredients}}" wx:key="name" class="ing-item">
        <text class="{{item.stockQuantity >= item.amount ? 'has' : 'miss'}}">
          {{item.name}} {{item.amount}}{{item.unit}}
        </text>
      </view>
    </view>
  </view>

  <!-- 缺少食材 -->
  <view wx:if="{{recipe.missingIngredients.length > 0}}" class="missing-section mt-12">
    <text class="text-sm text-warning">缺少：</text>
    <text wx:for="{{recipe.missingIngredients}}" wx:key="name" class="text-sm text-warning">
      {{item.name}} {{item.amount - item.stockQuantity}}{{item.unit}}
      <text wx:if="{{index < recipe.missingIngredients.length - 1}}">、</text>
    </text>
  </view>

  <!-- 替代建议 -->
  <view wx:if="{{recipe.substitues.length > 0}}" class="sub-section mt-12">
    <text class="text-sm text-primary">替代建议：</text>
    <text wx:for="{{recipe.substitues}}" wx:key="ingredient" class="text-sm text-primary">
      {{item.suggestion}}
      <text wx:if="{{index < recipe.substitues.length - 1}}">；</text>
    </text>
  </view>

  <!-- 视频来源 -->
  <view wx:if="{{video}}" class="video-source flex-between mt-12">
    <view class="flex-row">
      <text class="platform-tag tag-blue">{{video.platform}}</text>
      <text class="video-title ellipsis ml-12">{{video.title}}</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="recipe-actions flex-between mt-24">
    <view class="action-btn detail-btn" catchtap="onDetail">
      <text>查看详情</text>
    </view>
    <view class="action-btn video-btn" catchtap="onWatchVideo">
      <text>看原视频</text>
    </view>
  </view>
</view>
